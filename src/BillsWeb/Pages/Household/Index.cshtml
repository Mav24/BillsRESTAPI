@page
@model HouseholdIndexModel
@{
    ViewData["Title"] = "Household";
}

<div class="page-header">
    <h1>My Household</h1>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Household != null)
{
    <div class="household-card">
        <h2>@Model.Household.Name</h2>
        <p><small>Created: @Model.Household.CreatedAt.ToString("MMMM dd, yyyy")</small></p>
        
        <h3>Members</h3>
        @if (Model.Household.Members.Any())
        {
            <ul class="members-list">
                @foreach (var member in Model.Household.Members)
                {
                    <li>
                        <strong>@member.Username</strong> - @member.Email
                    </li>
                }
            </ul>
        }
        else
        {
            <p>No members in this household yet.</p>
        }

        <div class="household-actions">
            <h3>Invite Member</h3>
            <form method="post" asp-page-handler="Invite">
                <div class="form-group">
                    <input type="email" name="email" placeholder="Enter email address" class="form-control" required />
                </div>
                <div class="form-check mt-2 mb-2">
                    <input type="checkbox" name="shareExistingBills" value="true" class="form-check-input" id="shareExistingBills" />
                    <label class="form-check-label" for="shareExistingBills">Share all current household bills with the new member</label>
                </div>
                <button type="submit" class="btn btn-primary">Send Invitation</button>
            </form>
        </div>

        <div class="household-leave">
            <h3>Leave Household</h3>
            <p class="text-muted">If you leave this household, you will no longer have access to shared bills and information.</p>
            <form method="post" asp-page-handler="Leave">
                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to leave this household? This action cannot be undone.')">Leave Household</button>
            </form>
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <p>You're not part of a household yet.</p>
        <form method="post" asp-page-handler="Create">
            <div class="form-group">
                <label>Household Name</label>
                <input type="text" name="name" placeholder="Enter household name" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary">Create Household</button>
        </form>
    </div>
}
