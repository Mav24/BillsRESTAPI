@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

@if (Model.LoginSuccess)
{
    <meta http-equiv="refresh" content="3; url=/billsweb/bills/index">
    <div class="alert alert-success" style="margin: 20px; padding: 20px; text-align: center;">
        <h3>? Login Successful!</h3>
        <p>Welcome back! Redirecting to your bills in 3 seconds...</p>
        <p>If you are not redirected, <a href="/billsweb/bills/index">click here</a>.</p>
        <p><small>Session ID: @Model.HttpContext.Session.Id</small></p>
    </div>
    <script>
        console.log('Login success page loaded');
        console.log('All cookies:', document.cookie);
        console.log('Redirecting in 3 seconds to /billsweb/bills/index');
    </script>
}
else
{
<div class="auth-container">
    <div class="auth-card">
        <h2>Login</h2>
        
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="form-group">
                <label asp-for="Input.Username"></label>
                <input asp-for="Input.Username" class="form-control" />
                <span asp-validation-for="Input.Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" class="form-control" type="password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Login</button>
        </form>

        <div class="auth-links">
            <p>Don't have an account? <a asp-page="/Auth/Register">Register here</a></p>
        </div>
    </div>
</div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
