@page
@model BillsIndexModel
@{
    ViewData["Title"] = "My Bills";
}

<div class="page-header">
    <h1>My Bills</h1>
    <a asp-page="/Bills/Create" class="btn btn-primary">Add New Bill</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message) || TempData["Message"] is string msg)
{
    <div class="alert alert-success">@(Model.Message ?? TempData["Message"]?.ToString())</div>
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@if (Model.Bills.Any())
{
    @foreach (var monthGroup in Model.BillsByMonth)
    {
        var monthBills = monthGroup.ToList();
        var ownBills = monthBills.Where(b => !b.IsShared).ToList();
        var fullTotal = ownBills.Sum(b => b.Amount);
        var theyOweTotal = ownBills.Where(b => !b.IsPaid).Sum(b => b.AmountOverMinimum);
        var myShareTotal = ownBills.Where(b => !b.IsPaid).Sum(b => b.Amount - b.AmountOverMinimum);
        var paidTotal = ownBills.Where(b => b.IsPaid).Sum(b => b.Amount);
        var unpaidCount = ownBills.Count(b => !b.IsPaid);

        <div class="month-section">
            <div class="month-header">
                <div class="month-title-row">
                    <h2>@monthGroup.Key</h2>
                    <form method="post" asp-page-handler="ToggleMonthPaid" class="month-paid-toggle">
                        <input type="hidden" name="month" value="@monthGroup.Key" />
                        <input type="hidden" name="isPaid" value="@(unpaidCount > 0 ? "true" : "false")" />
                        <button type="submit" class="btn-month-paid @(unpaidCount == 0 ? "paid" : "unpaid")">
                            @if (unpaidCount == 0)
                            {
                                <span>✓ PAID</span>
                            }
                            else
                            {
                                <span>MARK PAID</span>
                            }
                        </button>
                    </form>
                </div>
                <div class="month-summary">
                    <span class="summary-item">
                        <strong>Full Total:</strong> $@fullTotal.ToString("N2")
                    </span>
                    <span class="summary-item">
                        <strong>My Share:</strong> $@myShareTotal.ToString("N2")
                    </span>
                    <span class="summary-item">
                        <strong>They Owe:</strong> $@theyOweTotal.ToString("N2")
                    </span>
                    <span class="summary-item">
                        <strong>Paid:</strong> $@paidTotal.ToString("N2")
                    </span>
                    @if (unpaidCount > 0)
                    {
                        <span class="summary-item unpaid-badge">
                            @unpaidCount Unpaid
                        </span>
                    }
                </div>
            </div>

            <div class="bills-grid">
                @foreach (var bill in monthBills)
                {
                    <div class="bill-card @(bill.IsPaid ? "paid" : "unpaid") @(bill.IsShared ? "shared" : "")">
                        <div class="bill-header">
                            <h3>@bill.BillName</h3>
                            <div class="bill-badges">
                                @if (bill.IsShared)
                                {
                                    <span class="badge badge-shared">Shared by @bill.SharedBy</span>
                                }
                                @if (bill.IsPaid)
                                {
                                    <span class="badge badge-success">Paid</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning">Unpaid</span>
                                }
                            </div>
                        </div>
                        <div class="bill-body">
                            <p><strong>Full Amount:</strong> $@bill.Amount.ToString("N2")</p>
                            <p><strong>Due Date:</strong> @bill.Date.ToString("MMM dd, yyyy")</p>
                            @if (bill.AmountOverMinimum > 0)
                            {
                                <p><strong>My Share:</strong> $@((bill.Amount - bill.AmountOverMinimum).ToString("N2"))</p>
                                <p><strong>They Owe:</strong> $@bill.AmountOverMinimum.ToString("N2")</p>
                            }
                            @if (bill.IsPaid && bill.PaidDate.HasValue)
                            {
                                <p><strong>Paid Date:</strong> @bill.PaidDate.Value.ToString("MMM dd, yyyy")</p>
                            }
                        </div>
                        <div class="bill-actions">
                            @if (!bill.IsShared)
                            {
                                <a asp-page="/Bills/Edit" asp-route-id="@bill.Id" class="btn btn-sm btn-secondary">Edit</a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@bill.Id" style="display: inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this bill?')">Delete</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
else
{
    <div class="empty-state">
        <p>No bills found. <a asp-page="/Bills/Create">Add your first bill</a></p>
    </div>
}

@section Scripts {
    <script>
        function toggleShareForm(billId) {
            var form = document.getElementById('share-form-' + billId);
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }
    </script>
}
