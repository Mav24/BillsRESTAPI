@page
@model BillsIndexModel
@{
    ViewData["Title"] = "My Bills";
}

<div class="page-header">
    <h1>My Bills</h1>
    <a asp-page="/Bills/Create" class="btn btn-primary">Add New Bill</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

@if (Model.Bills.Any())
{
    @foreach (var monthGroup in Model.BillsByMonth)
    {
        var monthBills = monthGroup.ToList();
        var totalAmount = monthBills.Sum(b => b.Amount);
        var paidAmount = monthBills.Where(b => b.IsPaid).Sum(b => b.Amount);
        var unpaidCount = monthBills.Count(b => !b.IsPaid);
        
        <div class="month-section">
            <div class="month-header">
                <div class="month-title-row">
                    <h2>@monthGroup.Key</h2>
                    <form method="post" asp-page-handler="ToggleMonthPaid" class="month-paid-toggle">
                        <input type="hidden" name="month" value="@monthGroup.Key" />
                        <input type="hidden" name="isPaid" value="@(unpaidCount > 0 ? "true" : "false")" />
                        <button type="submit" class="btn-month-paid @(unpaidCount == 0 ? "paid" : "unpaid")">
                            @if (unpaidCount == 0)
                            {
                                <span>? PAID</span>
                            }
                            else
                            {
                                <span>MARK PAID</span>
                            }
                        </button>
                    </form>
                </div>
                <div class="month-summary">
                    <span class="summary-item">
                        <strong>Total:</strong> $@totalAmount.ToString("N2")
                    </span>
                    <span class="summary-item">
                        <strong>Paid:</strong> $@paidAmount.ToString("N2")
                    </span>
                    @if (unpaidCount > 0)
                    {
                        <span class="summary-item unpaid-badge">
                            @unpaidCount Unpaid
                        </span>
                    }
                </div>
            </div>
            
            <div class="bills-grid">
                @foreach (var bill in monthBills)
                {
                    <div class="bill-card @(bill.IsPaid ? "paid" : "unpaid")">
                        <div class="bill-header">
                            <h3>@bill.BillName</h3>
                            @if (bill.IsPaid)
                            {
                                <span class="badge badge-success">Paid</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">Unpaid</span>
                            }
                        </div>
                        <div class="bill-body">
                            <p><strong>Amount:</strong> $@bill.Amount.ToString("N2")</p>
                            <p><strong>Due Date:</strong> @bill.Date.ToString("MMM dd, yyyy")</p>
                            @if (bill.AmountOverMinimum.HasValue)
                            {
                                <p><strong>Over Minimum:</strong> $@bill.AmountOverMinimum.Value.ToString("N2")</p>
                            }
                            @if (bill.IsPaid && bill.PaidDate.HasValue)
                            {
                                <p><strong>Paid Date:</strong> @bill.PaidDate.Value.ToString("MMM dd, yyyy")</p>
                            }
                        </div>
                        <div class="bill-actions">
                            <a asp-page="/Bills/Edit" asp-route-id="@bill.Id" class="btn btn-sm btn-secondary">Edit</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@bill.Id" style="display: inline;">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this bill?')">Delete</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
else
{
    <div class="empty-state">
        <p>No bills found. <a asp-page="/Bills/Create">Add your first bill</a></p>
    </div>
}
