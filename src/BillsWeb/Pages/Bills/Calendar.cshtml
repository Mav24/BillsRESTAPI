@page
@model BillsCalendarModel
@using System.Text.Json
@{
    ViewData["Title"] = "Bills Calendar";

    var prevMonth = Model.Month == 1 ? 12 : Model.Month - 1;
    var prevYear  = Model.Month == 1 ? Model.Year - 1 : Model.Year;
    var nextMonth = Model.Month == 12 ? 1 : Model.Month + 1;
    var nextYear  = Model.Month == 12 ? Model.Year + 1 : Model.Year;

    var billsJson = JsonSerializer.Serialize(
        Model.BillsByDay.ToDictionary(
            kvp => kvp.Key,
            kvp => kvp.Value.Select(b => new {
                id           = b.Id,
                name         = b.BillName,
                amount       = b.Amount,
                date         = b.Date.ToString("MMM dd, yyyy"),
                isPaid       = b.IsPaid,
                paidDate     = b.PaidDate.HasValue ? b.PaidDate.Value.ToString("MMM dd, yyyy") : (string?)null,
                amountOver   = b.AmountOverMinimum,
                myShare      = b.Amount - b.AmountOverMinimum,
                isShared     = b.IsShared,
                sharedBy     = b.SharedBy,
                shareWith    = b.ShareWith,
                sharedWith   = b.SharedWithNames,
                editUrl      = !b.IsShared ? $"{Request.PathBase}/bills/edit/{b.Id}" : null
            }).ToList()
        )
    );
}

<div class="page-header">
    <h1>My Bills</h1>
    <a asp-page="/Bills/Create" class="btn btn-primary">Add New Bill</a>
</div>

<div class="calendar-container">
    <!-- Monthly Summary Bar -->
    <div class="calendar-summary">
        <div class="cal-summary-item">
            <span class="cal-summary-label">Full Total</span>
            <span class="cal-summary-value">$@Model.MonthFullTotal.ToString("N2")</span>
        </div>
        <div class="cal-summary-item">
            <span class="cal-summary-label">My Share</span>
            <span class="cal-summary-value">$@Model.MonthMyShare.ToString("N2")</span>
        </div>
        <div class="cal-summary-item">
            <span class="cal-summary-label">They Owe</span>
            <span class="cal-summary-value">$@Model.MonthTheyOwe.ToString("N2")</span>
        </div>
        <div class="cal-summary-item">
            <span class="cal-summary-label">Paid</span>
            <span class="cal-summary-value">$@Model.MonthPaidTotal.ToString("N2")</span>
        </div>
        @if (Model.MonthUnpaidCount > 0)
        {
            <div class="cal-summary-item unpaid">
                <span class="cal-summary-label">Unpaid</span>
                <span class="cal-summary-value">@Model.MonthUnpaidCount bill@(Model.MonthUnpaidCount == 1 ? "" : "s")</span>
            </div>
        }
    </div>
    <!-- Month Navigation -->
    <div class="calendar-nav">
        <a asp-page="/Bills/Calendar" asp-route-year="@prevYear" asp-route-month="@prevMonth" class="btn btn-secondary">&#8249; Prev</a>
        <h2 class="calendar-month-title">@Model.MonthName</h2>
        <a asp-page="/Bills/Calendar" asp-route-year="@nextYear" asp-route-month="@nextMonth" class="btn btn-secondary">Next &#8250;</a>
    </div>

    <!-- Day-of-week headers -->
    <div class="calendar-grid">
        @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
        {
            <div class="calendar-dow-header">@day</div>
        }

        <!-- Empty cells before the 1st -->
        @for (int i = 0; i < Model.FirstDayOffset; i++)
        {
            <div class="calendar-day empty"></div>
        }

        <!-- Day cells -->
        @for (int d = 1; d <= Model.DaysInMonth; d++)
        {
            var hasBills  = Model.BillsByDay.ContainsKey(d);
            var bills     = hasBills ? Model.BillsByDay[d] : new();
            var allPaid   = hasBills && bills.All(b => b.IsPaid);
            var anyUnpaid = hasBills && bills.Any(b => !b.IsPaid);
            var isToday   = d == DateTime.Today.Day && Model.Month == DateTime.Today.Month && Model.Year == DateTime.Today.Year;

            var cellClass = "calendar-day";
            if (isToday)   cellClass += " today";
            if (hasBills)  cellClass += " has-bills";
            if (allPaid)   cellClass += " all-paid";
            if (anyUnpaid) cellClass += " has-unpaid";

            <div class="@cellClass" data-day="@d" @(hasBills ? "role=button tabindex=0" : "")>
                <span class="day-number">@d</span>
                @if (hasBills)
                {
                    <div class="bill-dots">
                        @foreach (var bill in bills)
                        {
                            <span class="bill-dot @(bill.IsPaid ? "dot-paid" : "dot-unpaid")" title="@bill.BillName"></span>
                        }
                    </div>
                    <span class="day-total">$@bills.Sum(b => b.Amount).ToString("N0")</span>
                }
            </div>
        }
    </div>

    <!-- Legend -->
    <div class="calendar-legend">
        <span><span class="bill-dot dot-paid"></span> Paid</span>
        <span><span class="bill-dot dot-unpaid"></span> Unpaid</span>
        <span><span class="legend-today"></span> Today</span>
    </div>

    <!-- Detail Panel -->
    <div class="calendar-detail-panel" id="detailPanel" style="display:none;">
        <div class="detail-panel-header">
            <h3 id="detailTitle"></h3>
            <button class="detail-close" id="detailClose" aria-label="Close">&times;</button>
        </div>
        <div class="detail-bills" id="detailBills"></div>
    </div>
    @foreach (var dayBills in Model.BillsByDay.Values)
    {
        @foreach (var bill in dayBills.Where(b => !b.IsShared))
        {
            <form id="delete-form-@bill.Id" method="post" asp-page-handler="Delete" asp-route-id="@bill.Id" style="display:none;"></form>
        }
    }
</div>

@section Scripts {
<script>
    var billsData = @Html.Raw(billsJson);

    function buildDetailHtml(bills) {
        if (!bills || bills.length === 0) return '<p>No bills on this day.</p>';
        return bills.map(function (b) {
            var statusBadge = b.isPaid
                ? '<span class="badge badge-success">Paid</span>'
                : '<span class="badge badge-warning">Unpaid</span>';
            var sharedBadge = b.isShared
                ? '<span class="badge badge-shared">Shared by ' + b.sharedBy + '</span>'
                : '';
            var splitInfo = b.amountOver > 0
                ? '<p><strong>My Share:</strong> $' + b.myShare.toFixed(2) + '</p>' +
                  '<p><strong>They Owe:</strong> $' + b.amountOver.toFixed(2) + '</p>'
                : '';
            var paidInfo = b.isPaid && b.paidDate
                ? '<p><strong>Paid On:</strong> ' + b.paidDate + '</p>'
                : '';
                var editBtn = !b.isShared && b.editUrl
                    ? '<div class="detail-bill-actions">' +
                          '<a href="' + b.editUrl + '" class="btn btn-sm btn-secondary">Edit</a>' +
                          '<button onclick="submitDelete(' + b.id + ')" class="btn btn-sm btn-danger">Delete</button>' +
                      '</div>'
                    : '';
            return '<div class="detail-bill-card ' + (b.isPaid ? 'paid' : 'unpaid') + '">' +
                '<div class="detail-bill-header">' +
                    '<strong class="detail-bill-name">' + b.name + '</strong>' +
                    '<div>' + statusBadge + sharedBadge + '</div>' +
                '</div>' +
                '<p><strong>Amount:</strong> $' + b.amount.toFixed(2) + '</p>' +
                '<p><strong>Due:</strong> ' + b.date + '</p>' +
                splitInfo +
                paidInfo +
                editBtn +
                '</div>';
        }).join('');
    }

    $(document).on('click keypress', '.calendar-day.has-bills', function (e) {
        if (e.type === 'keypress' && e.which !== 13) return;
        var day = parseInt($(this).data('day'));
        var bills = billsData[day] || [];
        var dateLabel = '@Model.MonthName'.replace(/(\w+ )(\d+)/, '$1' + day + ', $2').trim();
        // Build a simple label: "March 15, 2025"
        var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
        var label = monthNames[@(Model.Month - 1)] + ' ' + day + ', ' + @Model.Year;
        $('#detailTitle').text(label);
        $('#detailBills').html(buildDetailHtml(bills));
        $('#detailPanel').slideDown(200);
        $('html, body').animate({ scrollTop: $('#detailPanel').offset().top - 20 }, 300);
        // Highlight selected day
        $('.calendar-day').removeClass('selected');
        $(this).addClass('selected');
    });

    $('#detailClose').on('click', function () {
        $('#detailPanel').slideUp(200);
        $('.calendar-day').removeClass('selected');
    });
                function submitDelete(id) {
                    if (confirm('Are you sure you want to delete this bill?')) {
                        document.getElementById('delete-form-' + id).submit();
                    }
                }
            </script>
            }
