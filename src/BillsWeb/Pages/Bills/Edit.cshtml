@page "{id:int}"
@model EditBillModel
@{
    ViewData["Title"] = "Edit Bill";
}

<div class="form-container">
    <h2>Edit Bill</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post">
        <input type="hidden" asp-for="Input.Id" />

        <div class="form-group">
            <label asp-for="Input.BillName"></label>
            <input asp-for="Input.BillName" class="form-control" />
            <span asp-validation-for="Input.BillName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Amount"></label>
            <input asp-for="Input.Amount" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Input.Amount" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Date"></label>
            <input asp-for="Input.Date" class="form-control" type="date" value="@Model.Input.Date.ToString("yyyy-MM-dd")" />
            <span asp-validation-for="Input.Date" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.AmountOverMinimum"></label>
            <input asp-for="Input.AmountOverMinimum" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Input.AmountOverMinimum" class="text-danger"></span>
        </div>

        <div class="form-check">
            <input asp-for="Input.IsPaid" class="form-check-input" type="checkbox" />
            <label asp-for="Input.IsPaid" class="form-check-label"></label>
        </div>

        <div class="form-group" id="paidDateGroup" style="display: @(Model.Input.IsPaid ? "block" : "none");">
            <label asp-for="Input.PaidDate"></label>
            <input asp-for="Input.PaidDate" class="form-control" type="date" value="@(Model.Input.PaidDate?.ToString("yyyy-MM-dd"))" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update Bill</button>
            <a asp-page="/Bills/Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('Input_IsPaid').addEventListener('change', function() {
            document.getElementById('paidDateGroup').style.display = this.checked ? 'block' : 'none';
        });
    </script>
}
