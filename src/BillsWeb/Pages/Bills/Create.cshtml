@page
@model CreateBillModel
@{
    ViewData["Title"] = "Add New Bill";
}

<div class="form-container">
    <h2>Add New Bill</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="form-group">
            <label asp-for="Input.BillName"></label>
            <input asp-for="Input.BillName" class="form-control" />
            <span asp-validation-for="Input.BillName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Amount"></label>
            <input asp-for="Input.Amount" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Input.Amount" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Date"></label>
            <input asp-for="Input.Date" class="form-control" type="date" />
            <span asp-validation-for="Input.Date" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.AmountOverMinimum">Amount Over Minimum (Optional)</label>
            <input asp-for="Input.AmountOverMinimum" class="form-control" type="text" placeholder="Leave blank if not applicable" />
            <small class="form-text text-muted">Enter a decimal amount or leave blank</small>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Bill</button>
            <a asp-page="/Bills/Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
